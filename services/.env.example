# ===== Shared =====
NODE_ENV=development
INTERNAL_API_KEY=change-me-internal-api-key

# ===== MongoDB =====
MONGODB_URI=mongodb://mongodb:27017/wildernessfriends
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo-password

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== Firebase (Gateway) =====
FIREBASE_PROJECT_ID=wildernessfriends
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@wildernessfriends.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# ===== JWT =====
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_EXPIRY=1h

# ===== Gateway =====
GATEWAY_PORT=3000
PERMISSIONS_SERVICE_URL=http://permissions:5003
COMMERCE_SERVICE_URL=http://commerce:3004
IMAGE_SERVICE_URL=http://image-service:5001
LLM_SERVICE_URL=http://llm-service:5000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ===== Permissions Service =====
PERMISSIONS_PORT=5003
PERMISSIONS_MONGODB_DB=wildernessfriends

# ===== LLM Service =====
LLM_PORT=5000
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER-change-me
OPENAI_API_KEY=sk-PLACEHOLDER-change-me
GOOGLE_API_KEY=PLACEHOLDER-change-me
LLM_DEFAULT_TEXT_PROVIDER=anthropic
LLM_DEFAULT_IMAGE_PROVIDER=gemini

# ===== Image Service =====
IMAGE_PORT=5001
IMAGE_STORAGE_PATH=/storage
IMAGE_MAX_FILE_SIZE=10485760
