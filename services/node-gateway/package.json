{
  "name": "wf-gateway",
  "version": "1.0.0",
  "description": "WildernessFriends API Gateway",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --config tests/jest.config.js",
    "test:unit": "jest --config tests/jest.config.js --testPathPattern=unit",
    "test:integration": "jest --config tests/jest.config.js --testPathPattern=integration",
    "test:coverage": "jest --config tests/jest.config.js --coverage"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^13.2.0",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nock": "^14.0.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
