# Server
PORT=3000
NODE_ENV=development

# Firebase
FIREBASE_PROJECT_ID=wildernessfriends
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@wildernessfriends.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# JWT
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_EXPIRY=1h

# Internal API Key
INTERNAL_API_KEY=change-me-internal-api-key

# Service URLs
PERMISSIONS_SERVICE_URL=http://permissions:5003
COMMERCE_SERVICE_URL=http://commerce:3004
IMAGE_SERVICE_URL=http://image-service:5001
LLM_SERVICE_URL=http://llm-service:5000

# Redis
REDIS_URL=redis://redis:6379

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
